+---@private
+---@param node render.md.Node
+---@return string
+function Handler:math_highlight(node)
+    local buf = self.context.buf
+    local md_node = vim.treesitter.get_node({
+        bufnr = buf,
+        pos   = { node.start_row, node.start_col },
+        lang  = 'markdown',
+    })
+    if not md_node then return self.config.highlight end
+    local cur = md_node
+    while cur do
+        if cur:type() == 'block_quote' then
+            local bq_row = cur:start()
+            local value  = self.context.callout.values[bq_row]
+            if value then return value.config.highlight end
+            return self.config.highlight
+        end
+        cur = cur:parent()
+    end
+    return self.config.highlight
+end
+
 ---@private
 ---@param node render.md.Node
 ---@return render.md.Line
